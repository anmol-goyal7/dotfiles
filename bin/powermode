#!/bin/bash
# =============================================================================
# POWERMODE — Show current power mode
# Usage: powermode
# =============================================================================

MODE_FILE="/tmp/.power-mode"

if [ -f "$MODE_FILE" ]; then
  MODE=$(cat "$MODE_FILE")
else
  MODE="unknown"
fi

GOV=$(cat /sys/devices/system/cpu/cpu0/cpufreq/scaling_governor 2>/dev/null || echo "?")
TURBO=$(cat /sys/devices/system/cpu/intel_pstate/no_turbo 2>/dev/null)
MAX_PERF=$(cat /sys/devices/system/cpu/intel_pstate/max_perf_pct 2>/dev/null || echo "?")
BRIGHT=$(brightnessctl get 2>/dev/null || echo "?")
BRIGHT_MAX=$(brightnessctl max 2>/dev/null || echo "400")
BRIGHT_PCT=$(( BRIGHT * 100 / BRIGHT_MAX ))
WIFI_SAVE=$(iw dev wlp0s20f3 get power_save 2>/dev/null | awk '{print $NF}' || echo "?")

case "$MODE" in
  saver)       ICON="🔋" ;;
  performance) ICON="⚡" ;;
  balance)     ICON="⚖️ " ;;
  *)           ICON="❓" ;;
esac

echo "$ICON  Current mode : $MODE"
echo "   CPU governor : $GOV"
echo "   Turbo        : $([ "$TURBO" = "1" ] && echo "OFF" || echo "ON")"
echo "   Max perf     : ${MAX_PERF}%"
echo "   Brightness   : ${BRIGHT_PCT}%"
echo "   WiFi save    : $WIFI_SAVE"
