#!/bin/bash
# =============================================================================
# BATTERY SAVER — Maximum battery life, everything throttled
# Usage: saver
# =============================================================================

WIFI="wlp0s20f3"
MODE_FILE="/tmp/.power-mode"
NOTIF_ID=77701

step() { echo "  → $1"; }

echo "🔋 Applying Battery Saver..."

# --- 1. CPU Governor: powersave ---
step "CPU governor: powersave"
sudo cpupower frequency-set -g powersave -d 400MHz -u 2GHz >/dev/null 2>&1 || \
  sudo cpupower frequency-set -g powersave >/dev/null 2>&1 || true

# --- 2. Intel P-State: disable turbo, cap at 40% max perf ---
step "CPU turbo: OFF | max perf: 40%"
echo 1 | sudo tee /sys/devices/system/cpu/intel_pstate/no_turbo     >/dev/null 2>&1 || true
echo 40 | sudo tee /sys/devices/system/cpu/intel_pstate/max_perf_pct >/dev/null 2>&1 || true
echo 5  | sudo tee /sys/devices/system/cpu/intel_pstate/min_perf_pct >/dev/null 2>&1 || true

# --- 3. TLP: force battery profile ---
step "TLP: battery mode"
sudo tlp bat >/dev/null 2>&1 || true

# --- 4. Audio power save ---
step "Audio: power save"
echo 1 | sudo tee /sys/module/snd_hda_intel/parameters/power_save >/dev/null 2>&1 || true

# --- 5. Screen brightness: 25% ---
step "Screen brightness: 25%"
brightnessctl set 25% >/dev/null 2>&1 || true

# --- 6. WiFi power save: ON ---
step "WiFi power save: ON"
sudo iw dev "$WIFI" set power_save on 2>/dev/null || true

# --- 7. Bluetooth: OFF ---
step "Bluetooth: OFF"
bluetoothctl power off >/dev/null 2>&1 || true

# --- 8. Hyprland: kill animations & blur (saves GPU cycles) ---
step "Hyprland: animations OFF, blur OFF"
hyprctl keyword animations:enabled 0              >/dev/null 2>&1 || true
hyprctl keyword decoration:blur:enabled 0          >/dev/null 2>&1 || true
hyprctl keyword decoration:drop_shadow false        >/dev/null 2>&1 || true

# --- 9. Disable NMI watchdog ---
step "NMI watchdog: OFF"
echo 0 | sudo tee /proc/sys/kernel/nmi_watchdog >/dev/null 2>&1 || true

# --- 10. Mark current mode ---
echo "saver" > "$MODE_FILE"

# --- Done ---
TURBO_STATE=$(cat /sys/devices/system/cpu/intel_pstate/no_turbo 2>/dev/null)
MAX_PERF=$(cat /sys/devices/system/cpu/intel_pstate/max_perf_pct 2>/dev/null)
CURRENT_GOV=$(cat /sys/devices/system/cpu/cpu0/cpufreq/scaling_governor 2>/dev/null)
CURRENT_BRIGHT=$(brightnessctl get 2>/dev/null)

echo ""
echo "✓ Battery Saver ACTIVE"
echo "  CPU governor  : $CURRENT_GOV"
echo "  Turbo         : $([ "$TURBO_STATE" = "1" ] && echo "OFF" || echo "ON")"
echo "  Max perf      : ${MAX_PERF}%"
echo "  Brightness    : $CURRENT_BRIGHT / 400"

notify-send -u low -t 4000 \
  "🔋 Battery Saver" \
  "CPU: $CURRENT_GOV @ ${MAX_PERF}% cap\nTurbo: OFF | Screen: 25%\nWiFi: low power | BT: off\nAnimations: off" \
  2>/dev/null || true
