#!/bin/bash
# =============================================================================
# PERFORMANCE MODE — Maximum CPU speed, everything at full power
# Usage: performance
# =============================================================================

WIFI="wlp0s20f3"
MODE_FILE="/tmp/.power-mode"

step() { echo "  → $1"; }

echo "⚡ Applying Performance Mode..."

# --- 1. CPU Governor: performance ---
step "CPU governor: performance"
sudo cpupower frequency-set -g performance >/dev/null 2>&1 || true

# --- 2. Intel P-State: enable turbo, full performance ---
step "CPU turbo: ON | max perf: 100%"
echo 0   | sudo tee /sys/devices/system/cpu/intel_pstate/no_turbo     >/dev/null 2>&1 || true
echo 100 | sudo tee /sys/devices/system/cpu/intel_pstate/max_perf_pct >/dev/null 2>&1 || true
echo 50  | sudo tee /sys/devices/system/cpu/intel_pstate/min_perf_pct >/dev/null 2>&1 || true

# --- 3. TLP: force AC profile (acts as if plugged in) ---
step "TLP: AC/performance mode"
sudo tlp ac >/dev/null 2>&1 || true

# --- 4. Audio power save OFF ---
step "Audio: power save OFF"
echo 0 | sudo tee /sys/module/snd_hda_intel/parameters/power_save >/dev/null 2>&1 || true

# --- 5. Screen brightness: 100% ---
step "Screen brightness: 100%"
brightnessctl set 100% >/dev/null 2>&1 || true

# --- 6. WiFi power save: OFF ---
step "WiFi power save: OFF"
sudo iw dev "$WIFI" set power_save off 2>/dev/null || true

# --- 7. Bluetooth: ON ---
step "Bluetooth: ON"
bluetoothctl power on >/dev/null 2>&1 || true

# --- 8. Hyprland: animations + blur back on ---
step "Hyprland: animations ON, blur ON"
hyprctl keyword animations:enabled 1              >/dev/null 2>&1 || true
hyprctl keyword decoration:blur:enabled 1          >/dev/null 2>&1 || true
hyprctl keyword decoration:drop_shadow true         >/dev/null 2>&1 || true

# --- 9. NMI watchdog on (normal behavior) ---
step "NMI watchdog: ON"
echo 1 | sudo tee /proc/sys/kernel/nmi_watchdog >/dev/null 2>&1 || true

# --- 10. Mark current mode ---
echo "performance" > "$MODE_FILE"

# --- Done ---
TURBO_STATE=$(cat /sys/devices/system/cpu/intel_pstate/no_turbo 2>/dev/null)
MAX_PERF=$(cat /sys/devices/system/cpu/intel_pstate/max_perf_pct 2>/dev/null)
CURRENT_GOV=$(cat /sys/devices/system/cpu/cpu0/cpufreq/scaling_governor 2>/dev/null)
CURRENT_BRIGHT=$(brightnessctl get 2>/dev/null)

echo ""
echo "✓ Performance Mode ACTIVE"
echo "  CPU governor  : $CURRENT_GOV"
echo "  Turbo         : $([ "$TURBO_STATE" = "0" ] && echo "ON" || echo "OFF")"
echo "  Max perf      : ${MAX_PERF}%"
echo "  Brightness    : $CURRENT_BRIGHT / 400"

notify-send -u normal -t 4000 \
  "⚡ Performance Mode" \
  "CPU: $CURRENT_GOV @ turbo\nMax perf: ${MAX_PERF}% | Screen: 100%\nWiFi: full speed | BT: on\nAnimations: on" \
  2>/dev/null || true
